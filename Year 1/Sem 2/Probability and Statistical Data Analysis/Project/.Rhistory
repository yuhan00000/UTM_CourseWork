age <-datasets[ ,2]
heartRate <-datasets[,6]
x<-c(age)
y<-c(heartRate)
Age <- as.numeric(unlist(x))
HeartRate <- as.numeric(unlist(y))
cor(age,heartRate)
library(readxl)
datasets <- read_excel("datasets.xlsx")
View(datasets)
age <-datasets[ ,2]
heartRate <-datasets[,6]
x<-c(age)
y<-c(heartRate)
Age <- as.numeric(unlist(x))
HeartRate <- as.numeric(unlist(y))
cor(age,heartRate)
plot(Age,HeartRate,xlab = "Age", ylab = "Heart Rate", main = "Relationship between Age and Heart Rate")
cor.test(Age,HeartRate,method="pearson")
r<-cor(age,heartRate)
n<-8763
df_2=n-2
t2=(r/(sqrt((1-r^2)/(n-2))))
t2
dataset <- datasets
View(dataset)
gender.freq <- table(dataset[,3])
View(gender.freq)
heartrate.freq <- table(dataset[,6])
View(heartrate.freq)
library(dplyr)
mean_sd_count_heart_rates <- dataset %>%
group_by(Sex) %>%
summarize(
mean_heartRate = mean(`Heart Rate`, na.rm = TRUE),
sd_heartRate = sd(`Heart Rate`, na.rm = TRUE),
count = n()
)
print(mean_sd_count_heart_rates)
xbar1 = 75.4
xbar2 = 74.9
s1 = 20.6
s2 = 20.5
n1 = 2652
n2 = 6111
t0 = (xbar1-xbar2-0)/(sqrt((s1^2/n1)+(s2^2/n2)))
v = ((s1^2/n1)+(s2^2/n2))^2/((((s1^2/n1)^2)/(n1-1))+(((s2^2/n2)^2)/(n2-1)))
alpha = 0.05
t.alpha = qt(alpha/2, floor(v))
str(dataset)
male_heart_rate <- dataset %>% filter(Sex == "Male") %>% pull(`Heart Rate`)
female_heart_rate <- dataset %>% filter(Sex == "Female") %>% pull(`Heart Rate`)
t_test_result <- t.test(female_heart_rate, male_heart_rate)
print(t_test_result)
